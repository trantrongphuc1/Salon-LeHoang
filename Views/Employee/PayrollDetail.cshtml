@model Salon_LeHoang.Models.ViewModels.EmployeePayrollItem
@{
    ViewData["Title"] = $"Lương {Model.Employee.FullName}";
    var invoiceDetails = ViewBag.InvoiceDetails as List<Salon_LeHoang.Models.InvoiceDetail>;
    var month = (int)ViewBag.Month;
    var year = (int)ViewBag.Year;
    var cats = ViewBag.Categories as List<Salon_LeHoang.Models.ServiceCategory> ?? new List<Salon_LeHoang.Models.ServiceCategory>();
}

<div class="animate-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-2">
            <a asp-action="Payroll" asp-route-month="@month" asp-route-year="@year" class="btn btn-sm btn-outline-secondary no-print"><i class="bi bi-arrow-left"></i></a>
            <h4 class="fw-bold mb-0">Bảng lương: @Model.Employee.FullName — @month/@year</h4>
        </div>
        <button onclick="window.print();" class="btn btn-outline-gold no-print"><i class="bi bi-printer me-1"></i> In</button>
    </div>

    <div class="row g-4">
        <!-- Thông tin nhân viên -->
        <div class="col-md-4">
            <div class="card-custom p-4">
                <h6 class="fw-semibold mb-3" style="color:var(--gold);"><i class="bi bi-person-badge me-2"></i>Thông tin</h6>
                <table class="table table-sm table-borderless mb-0">
                    <tr><td class="text-muted">Họ tên:</td><td class="fw-semibold">@Model.Employee.FullName</td></tr>
                    <tr><td class="text-muted">Vị trí:</td><td>@(Model.Employee.Position ?? "—")</td></tr>
                    <tr><td class="text-muted">Lương CB:</td><td class="fw-bold" style="color:var(--gold);">@String.Format("{0:N0}đ", Model.Employee.BaseSalary)</td></tr>
                    @foreach (var cat in cats)
                    {
                        var rate = Model.Employee.CategoryCommissions.FirstOrDefault(c => c.CategoryId == cat.CategoryId)?.CommissionRate ?? 0;
                        <tr><td class="text-muted">H.Hồng @cat.CategoryName:</td><td><span class="badge badge-gold">@rate%</span></td></tr>
                    }
                </table>

                <hr style="border-color:var(--border-color);" />

                <h6 class="fw-semibold mb-3" style="color:var(--gold);"><i class="bi bi-calculator me-2"></i>Tính lương</h6>
                <table class="table table-sm table-borderless mb-0">
                    <tr>
                        <td class="text-muted">Ngày nghỉ:</td>
                        <td>
                            @Model.DaysOff ngày
                            @if (Model.ExcessDaysOff > 0)
                            {
                                <span class="badge badge-violation ms-1">Vượt @Model.ExcessDaysOff ngày</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted">Ngày trễ:</td>
                        <td>
                            @Model.LateDays ngày
                        </td>
                    </tr>
                    <tr><td class="text-muted">Ngày công thực tế:</td><td>@Model.ActualWorkDays / 28 ngày</td></tr>
                    <tr><td class="text-muted">Lương theo công:</td><td class="fw-semibold">@String.Format("{0:N0}đ", Model.BaseSalaryEarned)</td></tr>
                    @foreach (var cat in cats)
                    {
                        var comm = Model.CategoryCommissions.ContainsKey(cat.CategoryId) ? Model.CategoryCommissions[cat.CategoryId] : 0;
                        <tr><td class="text-muted">Hoa hồng @cat.CategoryName:</td><td class="text-info">@String.Format("{0:N0}đ", comm)</td></tr>
                    }
                    <tr><td class="text-muted fw-bold">Tổng hoa hồng:</td><td class="text-info fw-bold">@String.Format("{0:N0}đ", Model.TotalCommission)</td></tr>
                </table>

                <hr style="border-color:var(--border-color);" />

                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold fs-5">TỔNG LƯƠNG:</span>
                    <span class="fw-bold fs-4" style="color:var(--gold);">@String.Format("{0:N0}đ", Model.TotalSalary)</span>
                </div>

                @if (!string.IsNullOrEmpty(Model.AttendanceNotes) || !string.IsNullOrEmpty(Model.LateNotes))
                {
                    <hr style="border-color:var(--border-color);" />
                    @if (!string.IsNullOrEmpty(Model.AttendanceNotes))
                    {
                        <div class="small text-muted mb-1">
                            <strong>Ghi chú nghỉ:</strong> @Model.AttendanceNotes
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.LateNotes))
                    {
                        <div class="small text-muted">
                            <strong>Ghi chú trễ:</strong> @Model.LateNotes
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Chi tiết hóa đơn -->
        <div class="col-md-8">
            <div class="card-custom">
                <div class="card-header">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-receipt me-2" style="color:var(--gold);"></i>Hóa đơn đã thực hiện trong tháng</h6>
                </div>
                <div class="table-responsive">
                    <table class="table table-custom">
                        <thead>
                            <tr>
                                <th>Mã HĐ</th>
                                <th>Khách hàng</th>
                                <th>Dịch vụ</th>
                                <th>Danh mục</th>
                                <th>Giá</th>
                                <th>SL</th>
                                <th>Thành tiền</th>
                                <th>Hoa hồng</th>
                                <th>Ngày</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (invoiceDetails != null && invoiceDetails.Any())
                            {
                                decimal totalAmount = 0;
                                decimal totalComm = 0;
                                @foreach (var d in invoiceDetails)
                                {
                                    var lineTotal = d.Price * d.Quantity;
                                    var rate = Model.Employee.CategoryCommissions.FirstOrDefault(c => c.CategoryId == d.Service.CategoryId)?.CommissionRate ?? 0;
                                    
                                    var commission = lineTotal * rate / 100;
                                    totalAmount += lineTotal;
                                    totalComm += commission;
                                    <tr>
                                        <td><a asp-controller="Invoice" asp-action="Details" asp-route-id="@d.InvoiceId" class="text-decoration-none" style="color:var(--gold);">#@d.InvoiceId</a></td>
                                        <td>@d.Invoice.Customer.FullName</td>
                                        <td>@d.Service.ServiceName</td>
                                        <td><span class="badge bg-secondary">@(d.Service.Category?.CategoryName ?? "—")</span></td>
                                        <td>@String.Format("{0:N0}đ", d.Price)</td>
                                        <td>@d.Quantity</td>
                                        <td class="fw-semibold">@String.Format("{0:N0}đ", lineTotal)</td>
                                        <td class="text-info">@String.Format("{0:N0}đ", commission) <small>(@rate%)</small></td>
                                        <td class="text-muted">@d.Invoice.PaymentDate.ToString("dd/MM HH:mm")</td>
                                    </tr>
                                }
                                <tr style="border-top:2px solid var(--gold);">
                                    <td colspan="6" class="fw-bold text-end">TỔNG:</td>
                                    <td class="fw-bold" style="color:var(--gold);">@String.Format("{0:N0}đ", totalAmount)</td>
                                    <td class="fw-bold text-info">@String.Format("{0:N0}đ", totalComm)</td>
                                    <td></td>
                                </tr>
                            }
                            else
                            {
                                <tr><td colspan="8" class="text-center py-4 text-muted">Không có hóa đơn nào trong tháng.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
