@model Salon_LeHoang.Models.Employee
@{
    ViewData["Title"] = "Chi tiết nhân viên";
}

<div class="animate-in">
    <div class="d-flex align-items-center gap-2 mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
        <h4 class="fw-bold mb-0">Hồ sơ nhân viên</h4>
    </div>

    <div class="row g-4">
        <!-- Info Card -->
        <div class="col-md-4">
            <div class="card-custom p-4">
                <div class="text-center mb-3">
                    <div class="rounded-circle d-inline-flex align-items-center justify-content-center fw-bold fs-2" style="width:80px;height:80px;background:linear-gradient(135deg,var(--gold),#b8960c);color:#000;">
                        @Model.FullName.Substring(0,1).ToUpper()
                    </div>
                </div>
                <h5 class="text-center fw-bold">@Model.FullName</h5>
                <p class="text-center text-muted mb-3">@Model.Position</p>
                <div class="text-center mb-3">
                    <span class="badge badge-gold fs-6 px-3 py-2"><i class="bi bi-percent me-1"></i>Hoa hồng: @Model.CommissionRate%</span>
                </div>
                <hr style="border-color:var(--border-color);" />
                <div class="small text-muted">
                    <div class="d-flex justify-content-between mb-1">
                        <span>Số điện thoại:</span>
                        <span class="text-white">@Model.PhoneNumber</span>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span>Lương cơ bản:</span>
                        <span class="text-white">@String.Format("{0:N0}đ", Model.BaseSalary)</span>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span>Ngày vào làm:</span>
                        <span class="text-white">@Model.CreatedAt.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Trạng thái:</span>
                        <span class="@(Model.IsActive ? "text-success" : "text-danger")">@(Model.IsActive ? "Đang làm việc" : "Đã nghỉ")</span>
                    </div>
                </div>
                <div class="mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.EmployeeId" class="btn btn-sm btn-outline-gold w-100">Chỉnh sửa thông tin</a>
                </div>
            </div>
        </div>

        <!-- Performance -->
        <div class="col-md-8">
            <div class="card-custom">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-receipt me-2" style="color:var(--gold);"></i>Lịch sử phục vụ gần đây</h6>
                </div>
                <div class="table-responsive">
                    <table class="table table-dark table-custom mb-0">
                        <thead>
                            <tr>
                                <th>Mã HĐ</th>
                                <th>Dịch vụ</th>
                                <th>Khách hàng</th>
                                <th class="text-end">Tiền HĐ</th>
                                <th class="text-end">Ngày</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if(Model.InvoiceDetails.Any()){
                                @foreach (var d in Model.InvoiceDetails.OrderByDescending(x => x.Invoice.PaymentDate).Take(20))
                                {
                                    <tr>
                                        <td><a asp-controller="Invoice" asp-action="Details" asp-route-id="@d.InvoiceId" class="text-decoration-none" style="color:var(--gold);">#@d.InvoiceId</a></td>
                                        <td><span class="badge bg-secondary">@d.Service.ServiceName</span></td>
                                        <td>@d.Invoice.Customer.FullName</td>
                                        <td class="text-end fw-bold">@String.Format("{0:N0}đ", d.Price * d.Quantity)</td>
                                        <td class="text-end text-muted">@d.Invoice.PaymentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                }
                            } else {
                                <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có lịch sử phục vụ.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
