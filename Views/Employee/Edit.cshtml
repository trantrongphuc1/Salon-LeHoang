@model Salon_LeHoang.Models.Employee
@{
    ViewData["Title"] = "Sửa nhân viên";
}

<div class="animate-in">
    <div class="d-flex align-items-center gap-2 mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
        <h4 class="fw-bold mb-0">Sửa: @Model.FullName</h4>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-custom-error"><i class="bi bi-exclamation-circle me-2"></i>@ViewBag.Error</div>
    }

    <div class="card-custom">
        <div class="card-body p-4" style="background:var(--bg-card);">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="EmployeeId" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Họ tên <span class="text-danger">*</span></label>
                        <input asp-for="FullName" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Số điện thoại</label>
                        <input asp-for="PhoneNumber" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Vị trí</label>
                        <input asp-for="Position" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Lương cơ bản (VNĐ/tháng)</label>
                        <input asp-for="BaseSalary" type="number" class="form-control" min="0" />
                    </div>
                    <div class="col-12 mt-3">
                        <h6 class="fw-bold" style="color:var(--gold);"><i class="bi bi-percent me-2"></i>Cài đặt hoa hồng theo danh mục</h6>
                        <hr style="border-color:var(--border-color); opacity: 0.1;" />
                    </div>
                    
                    @{
                        var cats = ViewBag.Categories as List<Salon_LeHoang.Models.ServiceCategory> ?? new List<Salon_LeHoang.Models.ServiceCategory>();
                    }

                    @foreach (var cat in cats)
                    {
                        var rate = Model.CategoryCommissions.FirstOrDefault(c => c.CategoryId == cat.CategoryId)?.CommissionRate ?? 0;
                        <div class="col-md-4">
                            <label class="form-label">Hoa hồng: @cat.CategoryName (%)</label>
                            <input type="number" name="commissions[@cat.CategoryId]" step="0.5" class="form-control" min="0" max="100" value="@rate" />
                        </div>
                    }
                    <div class="col-md-6">
                        <div class="form-check form-switch mt-2">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label class="form-check-label" asp-for="IsActive">Đang hoạt động</label>
                        </div>
                    </div>
                    <div class="col-12 mt-4">
                        <button type="submit" class="btn btn-gold px-4"><i class="bi bi-check-circle me-1"></i> Lưu thay đổi</button>
                        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Hủy</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
