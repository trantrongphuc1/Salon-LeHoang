@model Salon_LeHoang.Models.ViewModels.AttendanceViewModel
@{
    ViewData["Title"] = "Chấm công";
}

<div class="animate-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0"><i class="bi bi-calendar-check-fill me-2" style="color:var(--gold);"></i>Chấm công tháng @Model.Month/@Model.Year</h4>
    </div>

    <!-- Month/Year picker -->
    <div class="card-custom mb-4">
        <div class="card-body p-3">
            <form method="get" class="d-flex gap-2 align-items-center flex-wrap">
                <label class="form-label mb-0 me-1 fw-semibold">Tháng:</label>
                <select name="month" class="form-select" style="width:auto;">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(m == Model.Month)">Tháng @m</option>
                    }
                </select>
                <select name="year" class="form-select" style="width:auto;">
                    @for (int y = DateTime.Now.Year - 2; y <= DateTime.Now.Year + 1; y++)
                    {
                        <option value="@y" selected="@(y == Model.Year)">@y</option>
                    }
                </select>
                <button type="submit" class="btn btn-outline-gold"><i class="bi bi-search me-1"></i>Xem</button>
            </form>
        </div>
    </div>

    <div class="card-custom">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-semibold">Bảng chấm công</h6>
                <div class="small text-muted">
                    <span class="badge bg-success me-1">≤ 2 ngày</span> Không trừ lương
                    <span class="badge badge-violation ms-2 me-1">&gt; 2 ngày</span> Vi phạm - trừ lương
                </div>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-dark table-custom">
                <thead>
                    <tr>
                        <th>Nhân viên</th>
                        <th>Vị trí</th>
                        <th>Ngày nghỉ</th>
                        <th>Ghi chú nghỉ</th>
                        <th>Ngày trễ</th>
                        <th>Ghi chú trễ</th>
                        <th class="text-end">Cập nhật</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Employee.FullName</td>
                            <td class="text-muted">@(item.Employee.Position ?? "—")</td>
                            <td colspan="5">
                                <form asp-action="UpdateAttendance" method="post" class="d-flex gap-2 align-items-center flex-wrap">
                                    <input type="hidden" name="employeeId" value="@item.Employee.EmployeeId" />
                                    <input type="hidden" name="month" value="@Model.Month" />
                                    <input type="hidden" name="year" value="@Model.Year" />
                                    
                                    <div class="d-flex align-items-center gap-1">
                                        <input type="number" name="daysOff" value="@item.DaysOff" min="0" max="31" class="form-control form-control-sm" style="width:60px;" title="Ngày nghỉ" />
                                        <input type="text" name="notes" value="@item.Notes" class="form-control form-control-sm" placeholder="Ghi chú nghỉ..." style="width:120px;" />
                                    </div>

                                    <div class="d-flex align-items-center gap-1">
                                        <input type="number" name="lateDays" value="@item.LateDays" min="0" max="31" class="form-control form-control-sm" style="width:60px;" title="Ngày trễ" />
                                        <input type="text" name="lateNotes" value="@item.LateNotes" class="form-control form-control-sm" placeholder="Ghi chú trễ..." style="width:120px;" />
                                    </div>

                                    <span class="flex-grow-1">
                                        @if (item.IsViolation)
                                        {
                                            <span class="badge badge-violation">
                                                <i class="bi bi-exclamation-triangle me-1"></i>Vi phạm nội quy
                                            </span>
                                        }
                                    </span>
                                    <button type="submit" class="btn btn-sm btn-gold text-nowrap"><i class="bi bi-save me-1"></i>Lưu</button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="6" class="text-center py-4 text-muted">Chưa có nhân viên nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
