@model IEnumerable<Salon_LeHoang.Models.Invoice>
@{
    ViewData["Title"] = "Quản lý Hóa đơn";
}

<div class="animate-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0"><i class="bi bi-receipt-cutoff me-2" style="color:var(--gold);"></i>Hóa đơn</h4>
        <a asp-action="Create" class="btn btn-gold"><i class="bi bi-plus-circle me-1"></i> Tạo hóa đơn</a>
    </div>

    <!-- Search & Filter -->
    <div class="card-custom mb-4">
        <div class="card-body p-3">
            <form method="get" class="d-flex gap-2 flex-wrap align-items-center">
                <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Tìm theo tên/SĐT khách..." style="max-width:250px;" />
                <input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control" style="width:auto;" />
                <span class="text-muted">→</span>
                <input type="date" name="toDate" value="@ViewBag.ToDate" class="form-control" style="width:auto;" />
                <button type="submit" class="btn btn-outline-gold"><i class="bi bi-search me-1"></i>Lọc</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Xóa lọc</a>
            </form>
        </div>
    </div>

    <div class="card-custom">
        <div class="table-responsive">
            <table class="table table-dark table-custom">
                <thead>
                    <tr>
                        <th>Mã HĐ</th>
                        <th>Khách hàng</th>
                        <th>Dịch vụ</th>
                        <th>Nhân viên</th>
                        <th>Tổng tiền</th>
                        <th>Giảm giá</th>
                        <th>Thanh toán</th>
                        <th>Điểm</th>
                        <th>Ngày</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inv in Model)
                    {
                        <tr>
                            <td><a asp-action="Details" asp-route-id="@inv.InvoiceId" class="text-decoration-none" style="color:var(--gold);">#@inv.InvoiceId</a></td>
                            <td class="fw-semibold">@inv.Customer.FullName</td>
                            <td>
                                @foreach (var d in inv.InvoiceDetails.Take(2))
                                {
                                    <span class="badge badge-gold me-1">@d.Service.ServiceName</span>
                                }
                                @if (inv.InvoiceDetails.Count > 2)
                                {
                                    <span class="badge bg-secondary">+@(inv.InvoiceDetails.Count - 2)</span>
                                }
                            </td>
                            <td>
                                @{
                                    var empNames = inv.InvoiceDetails.Select(d => d.Employee.FullName).Distinct();
                                }
                                @string.Join(", ", empNames)
                            </td>
                            <td class="fw-bold" style="color:var(--gold);">@String.Format("{0:N0}đ", inv.FinalAmount)</td>
                            <td class="text-muted">
                                @if (inv.DiscountAmount > 0)
                                {
                                    <span class="text-danger">-@String.Format("{0:N0}đ", inv.DiscountAmount)</span>
                                }
                                else { <text>—</text> }
                            </td>
                            <td><span class="badge bg-secondary">@inv.PaymentMethod</span></td>
                            <td class="text-success">+@inv.EarnedPoints</td>
                            <td class="text-muted">@inv.PaymentDate.ToString("dd/MM HH:mm")</td>
                            <td class="text-end text-nowrap">
                                <a asp-action="Details" asp-route-id="@inv.InvoiceId" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                                <a asp-action="Print" asp-route-id="@inv.InvoiceId" class="btn btn-sm btn-outline-gold" target="_blank"><i class="bi bi-printer"></i></a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="10" class="text-center py-4 text-muted">Chưa có hóa đơn nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
