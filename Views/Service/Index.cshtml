@model IEnumerable<Salon_LeHoang.Models.Service>
@{
    ViewData["Title"] = "Quản lý Dịch vụ";
}

<div class="animate-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0"><i class="bi bi-stars me-2" style="color:var(--gold);"></i>Dịch vụ</h4>
        <a asp-action="Create" class="btn btn-gold"><i class="bi bi-plus-circle me-1"></i> Thêm dịch vụ</a>
    </div>

    <!-- Search -->
    <div class="card-custom mb-4">
        <div class="card-body p-3">
            <form method="get" class="d-flex gap-2">
                <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Tìm theo tên dịch vụ..." />
                <button type="submit" class="btn btn-outline-gold"><i class="bi bi-search"></i></button>
            </form>
        </div>
    </div>

    <div class="card-custom">
        <div class="table-responsive">
            <table class="table table-dark table-custom">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Tên dịch vụ</th>
                        <th>Mô tả</th>
                        <th>Giá</th>
                        <th>Thời gian</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr class="@(!s.IsActive ? "opacity-50" : "")">
                            <td>@(string.IsNullOrEmpty(s.ServiceCode) ? "#" + s.ServiceId : s.ServiceCode)</td>
                            <td class="fw-semibold">@s.ServiceName</td>
                            <td class="text-muted" style="max-width:200px;">
                                <span class="text-truncate d-inline-block" style="max-width:200px;">@(s.Description ?? "—")</span>
                            </td>
                            <td class="fw-bold" style="color:var(--gold);">@String.Format("{0:N0}đ", s.Price)</td>
                            <td>@s.DurationMinutes phút</td>
                            <td>
                                @if (s.IsActive)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Tắt</span>
                                }
                            </td>
                            <td class="text-end text-nowrap">
                                <a asp-action="Edit" asp-route-id="@s.ServiceId" class="btn btn-sm btn-outline-gold"><i class="bi bi-pencil"></i></a>
                                <form asp-action="ToggleActive" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@s.ServiceId" />
                                    <button type="submit" class="btn btn-sm @(s.IsActive ? "btn-outline-secondary" : "btn-outline-success")" title="@(s.IsActive ? "Tắt" : "Bật")">
                                        <i class="bi @(s.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" class="text-center py-4 text-muted">Chưa có dịch vụ nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
