@model IEnumerable<Salon_LeHoang.Models.Service>
@{
    ViewData["Title"] = "Trang Chủ";
    ViewData["MetaDescription"] = "Khám phá danh sách các dịch vụ cắt, nhuộm, uốn tóc đẳng cấp tại Salon LeHoang. Trải nghiệm dịch vụ chuyên nghiệp.";
}


<!-- Hero Section -->
<section aria-labelledby="hero-heading" id="hero-section" class="hero-section text-center text-light d-flex align-items-center justify-content-center flex-column" style="background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1521590832167-7bfcFAA63EC3?q=80&w=2070&auto=format&fit=crop'); background-size: cover; background-position: center; height: 80vh; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); margin-bottom: 50px;">
    <h1 id="hero-heading" class="display-3 fw-bold text-uppercase mb-3 glow-text" style="font-family: 'Playfair Display', serif; letter-spacing: 2px;">Salon LeHoang</h1>
    <p class="lead mb-4 fs-4" style="max-width: 600px;">Nơi tôn vinh vẻ đẹp hoàn mỹ của bạn. Đặt lịch ngay hôm nay để nhận ưu đãi và điểm thưởng hấp dẫn!</p>
    <a href="/Customer/Booking" id="cta-book-now" class="btn btn-warning btn-lg fw-bold rounded-pill shadow-lg hover-scale px-5 py-3 text-dark">Lên Lịch Ngay</a>
</section>

<!-- Services Section -->
<section aria-labelledby="services-heading" id="services" class="container my-5">
    <div class="text-center mb-5">
        <h2 id="services-heading" class="display-5 fw-bold" style="font-family: 'Playfair Display', serif; color: #d4af37;">Dịch Vụ Của Chúng Tôi</h2>
        <div style="width: 80px; height: 3px; background-color: #d4af37; margin: 10px auto;"></div>
        <p class="text-muted">Khám phá các dịch vụ tóc đẳng cấp được thực hiện bởi chuyên gia</p>
    </div>

    <div class="row g-4 justify-content-center">
        @if(Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card bg-dark text-light h-100 service-card border-0 shadow-lg rounded-4 overflow-hidden position-relative">
                        <div class="card-body p-5 d-flex flex-column align-items-center text-center z-index-1">
                            <div class="service-icon-bg mb-4">
                                <i class="bi bi-scissors fs-1 text-warning"></i>
                            </div>
                            <h4 class="card-title fw-bold mb-3" style="color: #f8e192;">@item.ServiceName</h4>
                            <p class="card-text flex-grow-1 text-secondary">@item.Description</p>
                            
                            <div class="mt-4 pt-3 border-top border-secondary w-100 d-flex justify-content-between align-items-center">
                                <span class="fs-5 fw-bold text-white">@String.Format("{0:N0}đ", item.Price)</span>
                                <span class="badge bg-warning text-dark"><i class="bi bi-clock me-1"></i>@item.DurationMinutes phút</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <article class="col-12 text-center text-muted">
                <p><i class="bi bi-info-circle fs-2"></i></p>
                <p>Hiện chưa có dịch vụ nào trên hệ thống.</p>
            </article>
        }
    </div>
</section>

<style>
    body {
        background-color: #121212;
        color: #e0e0e0;
    }
    .glow-text {
        text-shadow: 0 0 10px rgba(212, 175, 55, 0.5), 0 0 20px rgba(212, 175, 55, 0.3);
    }
    .hover-scale {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-scale:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(212, 175, 55, 0.4) !important;
    }
    .service-card {
        transition: all 0.4s ease;
        background: linear-gradient(145deg, #1e1e1e, #121212) !important;
    }
    .service-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(212, 175, 55, 0.15) !important;
        border-bottom: 3px solid #d4af37 !important;
    }
    .service-icon-bg {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background-color: rgba(212, 175, 55, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }
    .service-card:hover .service-icon-bg {
        background-color: #d4af37;
    }
    .service-card:hover .service-icon-bg i {
        color: #121212 !important;
    }
</style>
