@model Salon_LeHoang.Models.User
@{
    ViewData["Title"] = "Chi tiết khách hàng";
}

<div class="animate-in">
    <div class="d-flex align-items-center gap-2 mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
        <h4 class="fw-bold mb-0">@Model.FullName</h4>
    </div>

    <div class="row g-4">
        <!-- Info Card -->
        <div class="col-md-4">
            <div class="card-custom p-4">
                <div class="text-center mb-3">
                    <div class="rounded-circle d-inline-flex align-items-center justify-content-center fw-bold fs-2" style="width:80px;height:80px;background:linear-gradient(135deg,var(--gold),var(--gold-dark));color:#000;">
                        @Model.FullName.Substring(0,1).ToUpper()
                    </div>
                </div>
                <h5 class="text-center fw-bold">@Model.FullName</h5>
                <p class="text-center text-muted mb-3">@Model.PhoneNumber</p>
                <div class="text-center mb-3">
                    <span class="badge badge-gold fs-5 px-3 py-2"><i class="bi bi-star-fill me-1"></i>@Model.Points điểm</span>
                </div>
                <hr style="border-color:var(--border-color);" />
                <div class="small text-muted">
                    <div class="d-flex justify-content-between mb-1">
                        <span>Trạng thái:</span>
                        <span>@(Model.IsActive ? "Hoạt động" : "Khóa")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span>Ngày tạo:</span>
                        <span>@Model.CreatedAt.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Tổng HĐ:</span>
                        <span>@Model.Invoices.Count</span>
                    </div>
                </div>
                <hr style="border-color:var(--border-color);" />
                <h6 class="small fw-semibold mb-2">Điều chỉnh điểm</h6>
                <form asp-action="AdjustPoints" method="post">
                    <input type="hidden" name="userId" value="@Model.UserId" />
                    <div class="mb-2">
                        <input type="number" name="points" class="form-control form-control-sm" placeholder="VD: 10 hoặc -5" required />
                    </div>
                    <div class="mb-2">
                        <input type="text" name="reason" class="form-control form-control-sm" placeholder="Lý do..." />
                    </div>
                    <button type="submit" class="btn btn-sm btn-outline-gold w-100">Cập nhật điểm</button>
                </form>
            </div>
        </div>

        <!-- History -->
        <div class="col-md-8">
            <!-- Invoices -->
            <div class="card-custom mb-4">
                <div class="card-header">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-receipt me-2" style="color:var(--gold);"></i>Lịch sử hóa đơn</h6>
                </div>
                <div class="table-responsive">
                    <table class="table table-custom">
                        <thead>
                            <tr>
                                <th>Mã HĐ</th>
                                <th>Dịch vụ</th>
                                <th>Tổng tiền</th>
                                <th>Điểm cộng</th>
                                <th>Ngày</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var inv in Model.Invoices.OrderByDescending(i => i.PaymentDate))
                            {
                                <tr>
                                    <td><a asp-controller="Invoice" asp-action="Details" asp-route-id="@inv.InvoiceId" class="text-decoration-none" style="color:var(--gold);">#@inv.InvoiceId</a></td>
                                    <td>
                                        @foreach (var d in inv.InvoiceDetails)
                                        {
                                            <span class="badge badge-gold me-1">@d.Service.ServiceName</span>
                                        }
                                    </td>
                                    <td class="fw-bold" style="color:var(--gold);">@String.Format("{0:N0}đ", inv.FinalAmount)</td>
                                    <td class="text-success">+@inv.EarnedPoints</td>
                                    <td class="text-muted">@inv.PaymentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            }
                            @if (!Model.Invoices.Any())
                            {
                                <tr><td colspan="5" class="text-center py-3 text-muted">Chưa có hóa đơn.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Point History -->
            <div class="card-custom">
                <div class="card-header">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-clock-history me-2" style="color:var(--gold);"></i>Lịch sử điểm</h6>
                </div>
                <div class="table-responsive">
                    <table class="table table-custom">
                        <thead>
                            <tr>
                                <th>Thay đổi</th>
                                <th>Mô tả</th>
                                <th>Ngày</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ph in Model.PointHistories.OrderByDescending(p => p.CreatedAt))
                            {
                                <tr>
                                    <td class="@(ph.PointsChanged > 0 ? "text-success fw-bold" : "text-danger fw-bold")">
                                        @(ph.PointsChanged > 0 ? "+" : "")@ph.PointsChanged
                                    </td>
                                    <td>@ph.Description</td>
                                    <td class="text-muted">@ph.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            }
                            @if (!Model.PointHistories.Any())
                            {
                                <tr><td colspan="3" class="text-center py-3 text-muted">Chưa có lịch sử.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
