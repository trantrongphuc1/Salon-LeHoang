@model IEnumerable<Salon_LeHoang.Models.Service>
@{
    ViewData["Title"] = "Đặt lịch dịch vụ";
    Layout = "_Layout";
}

<div class="row justify-content-center pt-4">
    <div class="col-md-8">
        <div class="card bg-dark text-light border-0 shadow-lg">
            <div class="card-header bg-transparent border-bottom border-warning pt-4 pb-3">
                <h3 class="text-center text-warning fw-bold m-0"><i class="bi bi-calendar-plus me-2"></i>Đặt Lịch Cắt Tóc & Dịch Vụ</h3>
            </div>
            <div class="card-body p-4">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="Booking" method="post">
                    <div class="mb-4">
                        <label class="form-label fw-bold text-light">1. Chọn dịch vụ</label>
                        <div class="row g-3">
                            @foreach (var item in Model)
                            {
                                <div class="col-md-6">
                                    <div class="form-check custom-checkbox custom-card-check">
                                        <input class="form-check-input" type="checkbox" name="serviceIds" value="@item.ServiceId" id="service_@item.ServiceId">
                                        <label class="form-check-label w-100 p-3 border rounded border-secondary hover-border-warning" for="service_@item.ServiceId">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span class="fw-bold">@item.ServiceName</span>
                                                <span class="text-warning">@String.Format("{0:N0}đ", item.Price)</span>
                                            </div>
                                            <small class="text-muted d-block mt-1">🕒 @item.DurationMinutes phút</small>
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-light">2. Chọn ngày & giờ</label>
                        <input type="datetime-local" class="form-control bg-dark text-light border-secondary hover-border-warning" name="appointmentDate" required min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-light">3. Ghi chú thêm (Tùy chọn)</label>
                        <textarea class="form-control bg-dark text-light border-secondary hover-border-warning" name="notes" rows="3" placeholder="Yêu cầu thợ cụ thể, loại tóc, v.v..."></textarea>
                    </div>

                    <div class="text-center mt-5">
                        <button type="submit" class="btn btn-warning btn-lg px-5 fw-bold rounded-pill shadow-lg hover-scale">Tiến Hành Đặt Lịch</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .custom-card-check .form-check-input {
        display: none;
    }
    .custom-card-check .form-check-label {
        cursor: pointer;
        transition: all 0.2s ease-in-out;
    }
    .custom-card-check .form-check-input:checked + .form-check-label {
        border-color: #d4af37 !important;
        background-color: rgba(212, 175, 55, 0.1);
        box-shadow: 0 0 10px rgba(212, 175, 55, 0.2);
    }
    .hover-border-warning:focus, .hover-border-warning:hover {
        border-color: #d4af37 !important;
        box-shadow: none;
        outline: none;
    }
    input[type="datetime-local"]::-webkit-calendar-picker-indicator {
        filter: invert(1);
        opacity: 0.7;
    }
</style>
