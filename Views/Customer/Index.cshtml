@model IEnumerable<Salon_LeHoang.Models.User>
@{
    ViewData["Title"] = "Quản lý Khách hàng";
}

<div class="animate-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0"><i class="bi bi-people-fill me-2" style="color:var(--gold);"></i>Khách hàng</h4>
        <a asp-action="Create" class="btn btn-gold"><i class="bi bi-person-plus me-1"></i> Thêm khách hàng</a>
    </div>

    <div class="card-custom mb-4">
        <div class="card-body p-3">
            <form method="get" class="d-flex gap-2">
                <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Tìm theo tên hoặc SĐT..." />
                <button type="submit" class="btn btn-outline-gold"><i class="bi bi-search"></i></button>
            </form>
        </div>
    </div>

    <div class="card-custom">
        <div class="table-responsive">
            <table class="table table-custom">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Họ tên</th>
                        <th>Số điện thoại</th>
                        <th>Điểm tích lũy</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td>#@c.UserId</td>
                            <td class="fw-semibold">@c.FullName</td>
                            <td>@c.PhoneNumber</td>
                            <td>
                                <span class="badge badge-gold fs-6">
                                    <i class="bi bi-star-fill me-1"></i>@c.Points
                                </span>
                            </td>
                            <td>
                                @if (c.IsActive) { <span class="badge bg-success">Hoạt động</span> }
                                else { <span class="badge bg-secondary">Khóa</span> }
                            </td>
                            <td class="text-muted">@c.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="text-end text-nowrap">
                                <a asp-action="Details" asp-route-id="@c.UserId" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@c.UserId" class="btn btn-sm btn-outline-gold"><i class="bi bi-pencil"></i></a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" class="text-center py-4 text-muted">Chưa có khách hàng nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
