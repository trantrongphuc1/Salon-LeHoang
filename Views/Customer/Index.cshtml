@model IEnumerable<Salon_LeHoang.Models.Appointment>
@{
    ViewData["Title"] = "Bảng điều khiển cá nhân";
    Layout = "_Layout";
}

<div class="row pt-4">
    <div class="col-md-4 mb-4">
        <div class="card bg-dark text-light border-warning shadow">
            <div class="card-body text-center">
                <i class="bi bi-person-circle display-4 text-warning mb-3"></i>
                <h4 class="card-title">@User.Identity.Name</h4>
                <hr class="border-secondary" />
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <span class="fs-5">Điểm tích lũy:</span>
                    <span class="fs-3 fw-bold text-warning glow-text">@ViewBag.Points <i class="bi bi-star-fill fs-5"></i></span>
                </div>
                <div class="mt-4">
                    <a href="/Customer/Booking" class="btn btn-warning w-100 fw-bold">Đặt lịch mới</a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card bg-dark text-light border-0 shadow">
            <div class="card-header bg-transparent border-bottom border-secondary pb-3">
                <h4 class="mb-0 text-warning"><i class="bi bi-calendar2-check me-2"></i>Lịch sử đặt lịch gần đây</h4>
            </div>
            <div class="card-body p-0">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success m-3">@TempData["Success"]</div>
                }

                @if(Model != null && Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-dark table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Thời gian</th>
                                    <th>Dịch vụ</th>
                                    <th>Thành tiền</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach(var item in Model)
                                {
                                    <tr>
                                        <td>@item.AppointmentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            @foreach(var detail in item.AppointmentDetails)
                                            {
                                                <span class="badge bg-secondary me-1">@detail.Service.ServiceName</span>
                                            }
                                        </td>
                                        <td>@String.Format("{0:N0}đ", item.AppointmentDetails.Sum(d => d.Price))</td>
                                        <td>
                                            @if (item.Status == "Pending")
                                            {
                                                <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i>Chờ xác nhận</span>
                                            }
                                            else if (item.Status == "Confirmed")
                                            {
                                                <span class="badge bg-info text-dark"><i class="bi bi-check2-circle me-1"></i>Đã xếp lịch</span>
                                            }
                                            else if (item.Status == "Completed")
                                            {
                                                <span class="badge bg-success"><i class="bi bi-check-all me-1"></i>Hoàn thành</span>
                                            }
                                            else if (item.Status == "Cancelled")
                                            {
                                                <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Đã hủy</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center p-5 text-muted">
                        <i class="bi bi-journal-x fs-1 mb-3"></i>
                        <p>Bạn chưa có lịch hẹn nào.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
