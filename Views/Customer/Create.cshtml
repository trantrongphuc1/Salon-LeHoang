@model Salon_LeHoang.Models.User
@{
    ViewData["Title"] = "Thêm khách hàng";
}

<div class="animate-in">
    <div class="d-flex align-items-center gap-2 mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
        <h4 class="fw-bold mb-0">Thêm khách hàng mới</h4>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-custom-error"><i class="bi bi-exclamation-circle me-2"></i>@ViewBag.Error</div>
    }

    <div class="card-custom">
        <div class="card-body p-4" style="background:var(--bg-card);">
            <form asp-action="Create" method="post">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Họ tên <span class="text-danger">*</span></label>
                        <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="0901234567" />
                    </div>
                    <div class="col-12 mt-4">
                        <button type="submit" class="btn btn-gold px-4"><i class="bi bi-check-circle me-1"></i> Thêm khách hàng</button>
                        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Hủy</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
