@model Salon_LeHoang.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="animate-in">
    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-4 col-sm-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-muted small mb-1">Doanh thu hôm nay</div>
                        <div class="fs-4 fw-bold" style="color: var(--gold);">@String.Format("{0:N0}đ", Model.TodayRevenue)</div>
                        <div class="text-muted small mt-1">@Model.TodayInvoiceCount hóa đơn</div>
                    </div>
                    <div class="rounded-3 p-2" style="background:rgba(212,175,55,0.1);">
                        <i class="bi bi-cash-coin fs-4" style="color:var(--gold);"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-sm-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-muted small mb-1">Doanh thu tháng này</div>
                        <div class="fs-4 fw-bold text-info">@String.Format("{0:N0}đ", Model.MonthRevenue)</div>
                        <div class="text-muted small mt-1">@Model.MonthInvoiceCount hóa đơn</div>
                    </div>
                    <div class="rounded-3 p-2" style="background:rgba(59,130,246,0.1);">
                        <i class="bi bi-graph-up-arrow fs-4 text-info"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-sm-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-muted small mb-1">Khách hàng</div>
                        <div class="fs-4 fw-bold text-success">@Model.TotalCustomers</div>
                        <div class="text-muted small mt-1">@Model.TotalEmployees nhân viên · @Model.TotalServices dịch vụ</div>
                    </div>
                    <div class="rounded-3 p-2" style="background:rgba(16,185,129,0.1);">
                        <i class="bi bi-people-fill fs-4 text-success"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Invoice" asp-action="Create" class="btn btn-gold">
                    <i class="bi bi-plus-circle me-1"></i> Tạo hóa đơn mới
                </a>
                <a asp-controller="Customer" asp-action="Create" class="btn btn-outline-gold">
                    <i class="bi bi-person-plus me-1"></i> Thêm khách hàng
                </a>
                <a asp-controller="Employee" asp-action="Attendance" class="btn btn-outline-gold">
                    <i class="bi bi-calendar-check me-1"></i> Chấm công
                </a>
                <a asp-controller="Employee" asp-action="Payroll" class="btn btn-outline-gold">
                    <i class="bi bi-cash-stack me-1"></i> Bảng lương
                </a>
            </div>
        </div>
    </div>

    <!-- Recent Invoices -->
    <div class="card-custom">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-semibold"><i class="bi bi-receipt me-2" style="color:var(--gold);"></i>Hóa đơn gần đây</h6>
            <a asp-controller="Invoice" asp-action="Index" class="btn btn-sm btn-outline-gold">Xem tất cả</a>
        </div>
        <div class="table-responsive">
            <table class="table table-dark table-custom">
                <thead>
                    <tr>
                        <th>Mã HĐ</th>
                        <th>Khách hàng</th>
                        <th>Dịch vụ</th>
                        <th>Tổng tiền</th>
                        <th>Thanh toán</th>
                        <th>Ngày</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentInvoices.Any())
                    {
                        @foreach (var inv in Model.RecentInvoices)
                        {
                            <tr>
                                <td><a asp-controller="Invoice" asp-action="Details" asp-route-id="@inv.InvoiceId" class="text-decoration-none" style="color:var(--gold);">#@inv.InvoiceId</a></td>
                                <td>@inv.Customer.FullName</td>
                                <td>
                                    @foreach (var d in inv.InvoiceDetails.Take(2))
                                    {
                                        <span class="badge badge-gold me-1">@d.Service.ServiceName</span>
                                    }
                                    @if (inv.InvoiceDetails.Count > 2)
                                    {
                                        <span class="badge bg-secondary">+@(inv.InvoiceDetails.Count - 2)</span>
                                    }
                                </td>
                                <td class="fw-bold" style="color:var(--gold);">@String.Format("{0:N0}đ", inv.FinalAmount)</td>
                                <td><span class="badge bg-secondary">@inv.PaymentMethod</span></td>
                                <td class="text-muted">@inv.PaymentDate.ToString("dd/MM HH:mm")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">Chưa có hóa đơn nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
