@model IEnumerable<Salon_LeHoang.Models.Appointment>
@{
    ViewData["Title"] = "Quản trị hệ thống";
    Layout = "_Layout";
}

<div class="row pt-4">
    <div class="col-12 mb-4 d-flex justify-content-between align-items-center">
        <h2 class="text-warning fw-bold m-0"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="col-12">
        <div class="card bg-dark text-light border-0 shadow">
            <div class="card-header bg-transparent border-bottom border-warning pb-3">
                <h4 class="mb-0 text-warning"><i class="bi bi-list-task me-2"></i>Quản lý Đặt Lịch & Hoá Đơn</h4>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-dark table-hover mb-0 align-middle">
                        <thead>
                            <tr>
                                <th>Mã</th>
                                <th>Khách hàng</th>
                                <th>Liên hệ</th>
                                <th>Lịch hẹn</th>
                                <th>Dịch vụ</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var item in Model)
                            {
                                var totalAmount = item.AppointmentDetails.Sum(ad => ad.Price);
                                <tr>
                                    <td>#@item.AppointmentId</td>
                                    <td>@item.User.FullName</td>
                                    <td>@item.User.PhoneNumber</td>
                                    <td>
                                        <span class="text-info fw-bold">@item.AppointmentDate.ToString("dd/MM")</span>
                                        <br/>
                                        <small class="text-muted text-nowrap">@item.AppointmentDate.ToString("HH:mm")</small>
                                    </td>
                                    <td>
                                        <div style="max-width: 200px;" class="text-truncate" title="@string.Join(", ", item.AppointmentDetails.Select(d => d.Service.ServiceName))">
                                            @foreach(var detail in item.AppointmentDetails)
                                            {
                                                <span class="badge bg-secondary me-1">@detail.Service.ServiceName</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="text-warning fw-bold">@String.Format("{0:N0}đ", totalAmount)</td>
                                    <td>
                                        @if (item.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                                        }
                                        else if (item.Status == "Confirmed")
                                        {
                                            <span class="badge bg-info text-dark">Đã xác nhận</span>
                                        }
                                        else if (item.Status == "Completed")
                                        {
                                            <span class="badge bg-success">Đã hoàn thành</span>
                                        }
                                        else if (item.Status == "Cancelled")
                                        {
                                            <span class="badge bg-danger">Đã hủy</span>
                                        }
                                    </td>
                                    <td class="text-end text-nowrap">
                                        @if(item.Status == "Pending")
                                        {
                                            <form asp-action="UpdateStatus" method="post" class="d-inline">
                                                <input type="hidden" name="appointmentId" value="@item.AppointmentId" />
                                                <input type="hidden" name="status" value="Confirmed" />
                                                <button type="submit" class="btn btn-sm btn-info" title="Xác nhận lịch"><i class="bi bi-check2"></i></button>
                                            </form>
                                            <form asp-action="UpdateStatus" method="post" class="d-inline">
                                                <input type="hidden" name="appointmentId" value="@item.AppointmentId" />
                                                <input type="hidden" name="status" value="Cancelled" />
                                                <button type="submit" class="btn btn-sm btn-danger" title="Hủy lịch" onclick="return confirm('Bạn có chắc chắn huỷ lịch này?');"><i class="bi bi-x-circle"></i></button>
                                            </form>
                                        }
                                        else if(item.Status == "Confirmed")
                                        {
                                            <form asp-action="CompleteAndInvoice" method="post" class="d-inline">
                                                <input type="hidden" name="appointmentId" value="@item.AppointmentId" />
                                                <button type="submit" class="btn btn-sm btn-success" title="Hoàn tất & Tính điểm" onclick="return confirm('Xác nhận hoàn tất dịch vụ và cộng @((int)(totalAmount/10000)) điểm cho khách?');"><i class="bi bi-cash-coin me-1"></i>Chốt hoá đơn</button>
                                            </form>
                                            <form asp-action="UpdateStatus" method="post" class="d-inline">
                                                <input type="hidden" name="appointmentId" value="@item.AppointmentId" />
                                                <input type="hidden" name="status" value="Cancelled" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Hủy lịch" onclick="return confirm('Bạn có chắc chắn huỷ lịch này?');"><i class="bi bi-x"></i></button>
                                            </form>
                                        }
                                        else if (item.Status == "Completed")
                                        {
                                            <button class="btn btn-sm btn-secondary" disabled><i class="bi bi-check2-all"></i> Đã xong</button>
                                        }
                                    </td>
                                </tr>
                            }
                            
                            @if(!Model.Any())
                            {
                                <tr>
                                    <td colspan="8" class="text-center py-4 text-muted">Không có lịch hẹn nào.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
