@model Salon_LeHoang.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="animate-in">
    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-muted small mb-1">Hôm nay</div>
                        <div class="fs-5 fw-bold" style="color: var(--gold);">@String.Format("{0:N0}đ", Model.TodayRevenue)</div>
                        <div class="text-muted small mt-1">@Model.TodayInvoiceCount hóa đơn</div>
                    </div>
                    <div class="rounded-3 p-2" style="background:rgba(212,175,55,0.1);">
                        <i class="bi bi-cash-coin fs-5" style="color:var(--gold);"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-muted small mb-1">Tháng này</div>
                        <div class="fs-5 fw-bold text-info">@String.Format("{0:N0}đ", Model.MonthRevenue)</div>
                        <div class="text-muted small mt-1">@Model.MonthInvoiceCount hóa đơn</div>
                    </div>
                    <div class="rounded-3 p-2" style="background:rgba(59,130,246,0.1);">
                        <i class="bi bi-calendar-month fs-5 text-info"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-muted small mb-1">Năm nay</div>
                        <div class="fs-5 fw-bold text-success">@String.Format("{0:N0}đ", Model.YearRevenue)</div>
                        <div class="text-muted small mt-1">@DateTime.Now.Year</div>
                    </div>
                    <div class="rounded-3 p-2" style="background:rgba(16,185,129,0.1);">
                        <i class="bi bi-graph-up-arrow fs-5 text-success"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-muted small mb-1">Khách hàng</div>
                        <div class="fs-5 fw-bold text-warning">@Model.TotalCustomers</div>
                        <div class="text-muted small mt-1">@Model.TotalEmployees NV · @Model.TotalServices DV</div>
                    </div>
                    <div class="rounded-3 p-2" style="background:rgba(245,158,11,0.1);">
                        <i class="bi bi-people fs-5 text-warning"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <!-- Top Services -->
        <div class="col-md-6">
            <div class="card-custom h-100">
                <div class="card-header"><h6 class="mb-0 fw-semibold"><i class="bi bi-stars me-2" style="color:var(--gold);"></i>Top dịch vụ (Sử dụng nhiều)</h6></div>
                <div class="p-0">
                    <table class="table table-dark table-custom mb-0">
                        <thead><tr><th>Dịch vụ</th><th class="text-center">Số lần</th><th class="text-end">Doanh thu</th></tr></thead>
                        <tbody>
                            @foreach(var s in Model.TopServices){
                                <tr>
                                    <td class="fw-medium">@s.ServiceName</td>
                                    <td class="text-center"><span class="badge bg-secondary">@s.UsageCount</span></td>
                                    <td class="text-end text-info">@String.Format("{0:N0}đ", s.TotalRevenue)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- Top Customers -->
        <div class="col-md-6">
            <div class="card-custom h-100">
                <div class="card-header"><h6 class="mb-0 fw-semibold"><i class="bi bi-person-check me-2" style="color:var(--gold);"></i>Top khách hàng (Chi tiêu)</h6></div>
                <div class="p-0">
                    <table class="table table-dark table-custom mb-0">
                        <thead><tr><th>Khách hàng</th><th class="text-center">Số HĐ</th><th class="text-end">Tổng chi</th></tr></thead>
                        <tbody>
                            @foreach(var c in Model.TopCustomers){
                                <tr>
                                    <td>
                                        <div class="fw-medium">@c.FullName</div>
                                        <div class="small text-muted">@c.PhoneNumber</div>
                                    </td>
                                    <td class="text-center"><span class="badge bg-secondary">@c.InvoiceCount</span></td>
                                    <td class="text-end" style="color:var(--gold);">@String.Format("{0:N0}đ", c.TotalSpent)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Invoices -->
    <div class="card-custom">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-semibold"><i class="bi bi-receipt me-2" style="color:var(--gold);"></i>Hóa đơn gần đây</h6>
            <a asp-controller="Invoice" asp-action="Index" class="btn btn-sm btn-outline-gold">Xem tất cả</a>
        </div>
        <div class="table-responsive">
            <table class="table table-dark table-custom">
                <thead>
                    <tr>
                        <th>Mã HĐ</th>
                        <th>Khách hàng</th>
                        <th>Tổng tiền</th>
                        <th>Thanh toán</th>
                        <th>Ngày</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentInvoices.Any())
                    {
                        @foreach (var inv in Model.RecentInvoices)
                        {
                            <tr>
                                <td><a asp-controller="Invoice" asp-action="Details" asp-route-id="@inv.InvoiceId" class="text-decoration-none" style="color:var(--gold);">#@inv.InvoiceId</a></td>
                                <td>@inv.Customer.FullName</td>
                                <td class="fw-bold" style="color:var(--gold);">@String.Format("{0:N0}đ", inv.FinalAmount)</td>
                                <td><span class="badge bg-secondary">@inv.PaymentMethod</span></td>
                                <td class="text-muted">@inv.PaymentDate.ToString("dd/MM HH:mm")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có hóa đơn nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
