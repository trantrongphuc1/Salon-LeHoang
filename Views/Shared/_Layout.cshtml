<!DOCTYPE html>
<html lang="vi" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@(ViewData["MetaDescription"] ?? "Salon LeHoang - Hệ thống quản lý salon chuyên nghiệp")" />
    <title>@(ViewData["Title"]) - Salon LeHoang Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #b8960c;
            --gold-light: #d4af37;
            --gold-dark: #8a7109;
            --bg-primary: #ffffff;
            --bg-secondary: #f8f9fa;
            --bg-card: #ffffff;
            --bg-card-hover: #f1f3f5;
            --text-primary: #000000;
            --text-secondary: #475569;
            --border-color: rgba(0,0,0,0.08);
            --sidebar-width: 260px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            font-weight: 450;
            background-color: var(--bg-primary);
            color: var(--text-primary);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* Sidebar */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: var(--sidebar-width);
            height: 100vh;
            background: linear-gradient(180deg, #ffffff 0%, #f8f9fa 100%);
            border-right: 1px solid var(--border-color);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            transition: transform 0.3s ease;
        }

        .sidebar-brand {
            padding: 1.5rem;
            border-bottom: 1px solid var(--border-color);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .sidebar-brand-text {
            font-family: 'Playfair Display', serif;
            font-size: 1.4rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .sidebar-brand-icon {
            width: 38px;
            height: 38px;
            background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #000;
            font-size: 1.2rem;
        }

        .sidebar-nav {
            flex: 1;
            padding: 1rem 0.75rem;
            overflow-y: auto;
        }

        .nav-section-title {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-secondary);
            padding: 0.75rem 0.75rem 0.4rem;
            margin-top: 0.5rem;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.7rem 0.75rem;
            border-radius: 8px;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.2s ease;
            margin-bottom: 2px;
        }

        .sidebar-link:hover {
            background: rgba(212, 175, 55, 0.08);
            color: var(--gold);
        }

        .sidebar-link.active {
            background: linear-gradient(135deg, rgba(212, 175, 55, 0.15) 0%, rgba(212, 175, 55, 0.05) 100%);
            color: var(--gold);
            font-weight: 600;
        }

        .sidebar-link.active::before {
            content: '';
            position: absolute;
            left: 0;
            width: 3px;
            height: 24px;
            background: var(--gold);
            border-radius: 0 3px 3px 0;
        }

        .sidebar-link i {
            font-size: 1.1rem;
            width: 24px;
            text-align: center;
        }

        .sidebar-footer {
            padding: 1rem 0.75rem;
            border-top: 1px solid var(--border-color);
        }

        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
        }

        .topbar {
            position: sticky;
            top: 0;
            z-index: 999;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border-color);
            padding: 0.75rem 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .topbar-title {
            font-size: 1.1rem;
            font-weight: 600;
        }

        .page-content {
            padding: 1.5rem;
        }

        /* Cards */
        .stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.25rem;
            transition: all 0.3s ease;
        }

        .stat-card:hover {
            border-color: rgba(212, 175, 55, 0.2);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.3);
        }

        .card-custom {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            overflow: hidden;
        }

        .card-custom .card-header {
            background: transparent;
            border-bottom: 1px solid var(--border-color);
            padding: 1rem 1.25rem;
        }

        /* Tables */
        .table-custom {
            margin: 0;
        }

        .table-custom th {
            background: rgba(0,0,0,0.02);
            border-color: var(--border-color);
            color: var(--text-secondary);
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 0.75rem 1rem;
        }

        .table-custom td {
            border-color: var(--border-color);
            padding: 0.75rem 1rem;
            vertical-align: middle;
        }

        .table-custom tbody tr:hover {
            background: rgba(212, 175, 55, 0.03);
        }

        /* Buttons */
        .btn-gold {
            background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
            color: #000;
            font-weight: 600;
            border: none;
            transition: all 0.3s ease;
        }

        .btn-gold:hover {
            background: linear-gradient(135deg, var(--gold-light) 0%, var(--gold) 100%);
            color: #000;
            transform: translateY(-1px);
            box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
        }

        .btn-outline-gold {
            border: 1px solid var(--gold);
            color: var(--gold);
            background: transparent;
            font-weight: 500;
        }

        .btn-outline-gold:hover {
            background: rgba(212, 175, 55, 0.1);
            color: var(--gold-light);
            border-color: var(--gold-light);
        }

        /* Forms */
        .form-control, .form-select {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            border-radius: 8px;
            padding: 0.6rem 0.85rem;
        }

        .form-control:focus, .form-select:focus {
            background: var(--bg-secondary);
            border-color: var(--gold);
            color: var(--text-primary);
            box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.15);
        }

        .form-label {
            font-weight: 500;
            font-size: 0.875rem;
            color: var(--text-secondary);
            margin-bottom: 0.4rem;
        }

        /* Badge styles */
        .badge-gold {
            background: rgba(212, 175, 55, 0.15);
            color: var(--gold);
            font-weight: 500;
        }

        .badge-violation {
            background: rgba(239, 68, 68, 0.15);
            color: #ef4444;
            font-weight: 600;
        }

        /* Alerts */
        .alert-custom-success {
            background: rgba(16, 185, 129, 0.1);
            border: 1px solid rgba(16, 185, 129, 0.2);
            color: #10b981;
            border-radius: 10px;
        }

        .alert-custom-error {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #ef4444;
            border-radius: 10px;
        }

        /* Animations */
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-in {
            animation: fadeInUp 0.4s ease forwards;
        }

        /* Print styles */
        @@media print {
            .sidebar, .topbar, .no-print { display: none !important; }
            .main-content { margin-left: 0 !important; }
            .page-content { padding: 0 !important; }
            body { background: #fff !important; color: #000 !important; }
            .card-custom { border: 1px solid #ddd !important; }
            .table-custom th, .table-custom td { border-color: #ddd !important; color: #000 !important; }
        }

        /* Responsive */
        @@media (max-width: 991.98px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.show { transform: translateX(0); }
            .main-content { margin-left: 0; }
            .sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,0.5);
                z-index: 999;
            }
            .sidebar-overlay.show { display: block; }
        }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.1); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(0,0,0,0.2); }
        /* Submenu */
        .sidebar-link[data-bs-toggle="collapse"] {
            position: relative;
        }

        .sidebar-link[data-bs-toggle="collapse"]::after {
            display: none;
        }

        .sidebar-link .chevron-icon {
            transition: transform 0.3s ease;
            font-size: 0.8rem;
        }

        .sidebar-link[aria-expanded="true"] .chevron-icon {
            transform: rotate(180deg);
        }

        .submenu-container {
            padding-left: 1rem;
            margin-bottom: 0.5rem;
        }

        .sidebar-link.active {
            position: relative;
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <a class="sidebar-brand" asp-controller="Admin" asp-action="Index">
            <div class="sidebar-brand-icon"><i class="bi bi-scissors"></i></div>
            <span class="sidebar-brand-text">LeHoang</span>
        </a>

        <nav class="sidebar-nav">
            <!-- Dashboard -->
            <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")"
               asp-controller="Admin" asp-action="Index">
                <i class="bi bi-grid-1x2-fill"></i> Dashboard
            </a>

            <!-- POS Link -->
            <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Pos" ? "active" : "")"
               asp-controller="Pos" asp-action="Index">
                <i class="bi bi-cart-plus-fill"></i> Bán hàng (POS)
            </a>

            <!-- Management Section -->
            <a class="sidebar-link @(new[] {"Service", "Customer", "Employee"}.Contains(ViewContext.RouteData.Values["controller"]?.ToString()) ? "" : "collapsed")" 
               data-bs-toggle="collapse" href="#manageSubmenu" role="button" 
               aria-expanded="@(new[] {"Service", "Customer", "Employee"}.Contains(ViewContext.RouteData.Values["controller"]?.ToString()) ? "true" : "false")">
                <i class="bi bi-layers-fill"></i> Quản lý
                <i class="bi bi-chevron-down ms-auto chevron-icon"></i>
            </a>
            
            <div class="collapse @(new[] {"Service", "Customer", "Employee"}.Contains(ViewContext.RouteData.Values["controller"]?.ToString()) ? "show" : "")" id="manageSubmenu">
                <div class="submenu-container">
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Service" ? "active" : "")"
                       asp-controller="Service" asp-action="Index">
                        <i class="bi bi-stars"></i> Dịch vụ
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ServiceCategory" ? "active" : "")"
                       asp-controller="ServiceCategory" asp-action="Index">
                        <i class="bi bi-folder2-open"></i> Danh mục dịch vụ
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" ? "active" : "")"
                       asp-controller="Customer" asp-action="Index">
                        <i class="bi bi-people-fill"></i> Khách hàng
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Employee" ? "active" : "")"
                       asp-controller="Employee" asp-action="Index">
                        <i class="bi bi-person-badge-fill"></i> Nhân viên
                    </a>
                </div>
            </div>

            <!-- Finance Section -->
            <a class="sidebar-link @(new[] {"Invoice", "Attendance", "Payroll"}.Contains(ViewContext.RouteData.Values["controller"]?.ToString()) || new[] {"Attendance", "Payroll"}.Contains(ViewContext.RouteData.Values["action"]?.ToString()) ? "" : "collapsed")" 
               data-bs-toggle="collapse" href="#financeSubmenu" role="button" 
               aria-expanded="@(new[] {"Invoice", "Attendance", "Payroll"}.Contains(ViewContext.RouteData.Values["controller"]?.ToString()) || new[] {"Attendance", "Payroll"}.Contains(ViewContext.RouteData.Values["action"]?.ToString()) ? "true" : "false")">
                <i class="bi bi-wallet2"></i> Tài chính
                <i class="bi bi-chevron-down ms-auto chevron-icon"></i>
            </a>

            <div class="collapse @(new[] {"Invoice", "Attendance", "Payroll"}.Contains(ViewContext.RouteData.Values["controller"]?.ToString()) || new[] {"Attendance", "Payroll"}.Contains(ViewContext.RouteData.Values["action"]?.ToString()) ? "show" : "")" id="financeSubmenu">
                <div class="submenu-container">
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoice" ? "active" : "")"
                       asp-controller="Invoice" asp-action="Index">
                        <i class="bi bi-receipt-cutoff"></i> Hóa đơn
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Attendance" ? "active" : "")"
                       asp-controller="Employee" asp-action="Attendance">
                        <i class="bi bi-calendar-check-fill"></i> Chấm công
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Payroll" ? "active" : "")"
                       href="javascript:void(0)" onclick="accessPayroll()">
                        <i class="bi bi-cash-stack"></i> Bảng lương
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "ProfitReport" ? "active" : "")"
                       asp-controller="Admin" asp-action="ProfitReport">
                        <i class="bi bi-graph-up-arrow"></i> Lợi nhuận
                    </a>
                </div>
            </div>
        </nav>

        <div class="sidebar-footer">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="sidebar-brand-icon" style="width:32px;height:32px;font-size:0.85rem;border-radius:8px;">
                        @User.Identity.Name?.Substring(0,1).ToUpper()
                    </div>
                    <div>
                        <div class="small fw-semibold text-dark">@User.Identity.Name</div>
                        <div style="font-size:0.7rem;" class="text-muted">Quản trị viên</div>
                    </div>
                </div>
                <a class="sidebar-link text-danger" asp-controller="Auth" asp-action="Logout">
                    <i class="bi bi-box-arrow-left"></i> Đăng xuất
                </a>
            }
        </div>
    </aside>

    <!-- Overlay for mobile -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <!-- Main content -->
    <div class="main-content">
        <div class="topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-sm btn-outline-secondary d-lg-none border-0" onclick="toggleSidebar()">
                    <i class="bi bi-list fs-5"></i>
                </button>
                <span class="topbar-title">@ViewData["Title"]</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="text-muted small"><i class="bi bi-clock me-1"></i>@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
        </div>

        <div class="page-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-custom-success d-flex align-items-center gap-2 animate-in" role="alert">
                    <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-custom-error d-flex align-items-center gap-2 animate-in" role="alert">
                    <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
                </div>
            }

            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Level 2 Password Modal -->
    <div class="modal fade" id="level2PasswordModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 12px;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="level2PasswordTitle"><i class="bi bi-shield-lock-fill text-warning me-2"></i>Xác thực bảo mật</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3" id="level2PasswordMessage">Vui lòng nhập mật khẩu cấp 2 để tiếp tục.</p>
                    <div class="input-group mb-2">
                        <input type="password" class="form-control" id="level2PasswordInput" placeholder="Mật khẩu cấp 2" autocomplete="new-password">
                        <button class="btn btn-outline-secondary bg-light" type="button" id="toggleLevel2Password" style="border-color: var(--border-color);">
                            <i class="bi bi-eye-slash text-muted" id="toggleLevel2PasswordIcon"></i>
                        </button>
                    </div>
                    <div id="level2PasswordError" class="text-danger small mb-3 d-none"></div>
                    <button type="button" class="btn btn-gold w-100" id="btnSubmitLevel2Password">Xác nhận</button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('show');
            document.getElementById('sidebarOverlay').classList.toggle('show');
        }

        // Auto-hide alerts after 5s
        setTimeout(() => {
            document.querySelectorAll('.alert').forEach(a => {
                a.style.transition = 'opacity 0.5s';
                a.style.opacity = '0';
                setTimeout(() => a.remove(), 500);
            });
        }, 5000);

        // Global Level 2 Password Logic
        let level2PasswordCallback = null;

        function requireLevel2Password(message, callback) {
            if (message) {
                document.getElementById('level2PasswordMessage').innerText = message;
            } else {
                document.getElementById('level2PasswordMessage').innerText = "Vui lòng nhập mật khẩu cấp 2 để tiếp tục.";
            }
            document.getElementById('level2PasswordInput').value = '';
            document.getElementById('level2PasswordError').classList.add('d-none');
            
            const input = document.getElementById('level2PasswordInput');
            const icon = document.getElementById('toggleLevel2PasswordIcon');
            input.type = 'password';
            icon.classList.remove('bi-eye');
            icon.classList.add('bi-eye-slash');

            level2PasswordCallback = callback;
            var myModal = new bootstrap.Modal(document.getElementById('level2PasswordModal'));
            myModal.show();
            
            document.getElementById('level2PasswordModal').addEventListener('shown.bs.modal', function () {
                document.getElementById('level2PasswordInput').focus();
            }, { once: true });
        }

        document.getElementById('toggleLevel2Password').addEventListener('click', function() {
            const input = document.getElementById('level2PasswordInput');
            const icon = document.getElementById('toggleLevel2PasswordIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            }
        });

        document.getElementById('btnSubmitLevel2Password').addEventListener('click', function() {
            submitLevel2Password();
        });

        document.getElementById('level2PasswordInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                submitLevel2Password();
            }
        });

        function submitLevel2Password() {
            const pwd = document.getElementById('level2PasswordInput').value;
            if (!pwd) {
                document.getElementById('level2PasswordError').innerText = "Vui lòng nhập mật khẩu!";
                document.getElementById('level2PasswordError').classList.remove('d-none');
                return;
            }
            if (pwd !== "cucvahoang") {
                document.getElementById('level2PasswordError').innerText = "Mật khẩu cấp 2 không đúng!";
                document.getElementById('level2PasswordError').classList.remove('d-none');
                return;
            }
            
            var myModalEl = document.getElementById('level2PasswordModal');
            var modal = bootstrap.Modal.getInstance(myModalEl);
            modal.hide();
            
            if (level2PasswordCallback) {
                level2PasswordCallback(pwd);
            }
        }

        function accessPayroll() {
            requireLevel2Password("Vui lòng nhập mật khẩu cấp 2 để xem bảng lương:", function(pwd) {
                window.location.href = '@Url.Action("Payroll", "Employee")?pwd=' + encodeURIComponent(pwd);
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
